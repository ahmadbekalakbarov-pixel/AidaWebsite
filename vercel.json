{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "server.js"
    },
    {
      "src": "/shop.html",
      "dest": "/shop.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
